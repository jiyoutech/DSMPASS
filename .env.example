# Required. Use a strong random value shared by backend and helper.
DSMPASS_HELPER_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32

# Host users open in the browser. Can be an IP or DNS name.
DSMPASS_ACCESS_HOST=127.0.0.1

# Management console. In the SPK this is configured during install.
DSMPASS_GO_LISTEN=0.0.0.0:25000
DSMPASS_TLS_ENABLED=true

# IDP public entry. The admin console can change IDP protocol and IDP port at runtime.
DSMPASS_PUBLIC_BASE_URL=https://127.0.0.1:25000

# Data and helper socket.
DSMPASS_DATA_DIR=./data
DSMPASS_DATABASE_URL=sqlite://./data/dsmpass.db
DSMPASS_HELPER_SOCKET=/run/dsmpass/helper.sock

# DSM targets. Default DSM ports are 5000 for HTTP and 5001 for HTTPS.
DSMPASS_DSM_REDIRECT_URL=http://127.0.0.1:5000/
DSMPASS_DSM_LOGIN_API=http://127.0.0.1:5000/webapi/entry.cgi
DSMPASS_DSM_TLS_SKIP_VERIFY=false

# Diagnostics should stay disabled in production.
DSMPASS_LOGIN_DIAGNOSTICS=false
